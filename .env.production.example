# Producción — Archivo de ejemplo
# Este archivo no contiene secretos reales. Es una plantilla de las variables
# requeridas para el entorno de producción en la VM de Azure.
# El archivo .env real debe crearse manualmente en el servidor con los valores correctos.

APP_NAME=MyPortfolio
APP_ENV=production
APP_KEY= # Generar con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://tudominio.com # Reemplazar con el dominio real

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Variables de Laravel que no cambian a menudo
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Configuración de Logs (más restrictivo en producción)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Base de datos — SQLite persistido vía volumen
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# Drivers (manteniendo driver database según estado actual)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Si en un futuro se añade Redis, estas variables estarán listas
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo (configurar con servicio de SMTP como Resend/Mailgun/Postmark)
MAIL_MAILER=smtp
MAIL_HOST=smtp.ejemplo.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
